{
  "name": "@achmadya-dev/mcp-postgres-query",
  "version": "0.2.2",
  "description": "Model Context Protocol (MCP) server for PostgreSQL to run SQL queries via stdio (read-only by default)",
  "type": "module",
  "author": "achmadya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/achmadya-dev/mcp-postgres-query.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "postgres",
    "postgresql",
    "database",
    "cursor"
  ],
  "main": "dist/index.js",
  "bin": {
    "mcp-postgres-query": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "start": "node dist/index.js",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "pnpm run build && changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@achmadya-dev/mcp-core": "^0.6.0",
    "pg": "8.13.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@jest/globals": "30.4.1",
    "@types/jest": "30.0.0",
    "@types/node": "22.10.0",
    "@types/pg": "8.11.10",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "typescript": "5.7.2"
  },
  "packageManager": "pnpm@10.33.0"
}
