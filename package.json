{
  "name": "@achmadya-dev/mcp-postgres-query",
  "version": "0.1.0",
  "description": "PostgreSQL database tool for Model Context Protocol (MCP) clients",
  "type": "module",
  "author": "achmadya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/achmadya-dev/mcp-postgres-query.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "postgres",
    "postgresql",
    "database",
    "cursor"
  ],
  "main": "dist/index.js",
  "bin": {
    "mcp-postgres-query": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.0",
    "pg": "8.13.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.10.0",
    "@types/pg": "8.11.10",
    "typescript": "5.7.2"
  }
}
